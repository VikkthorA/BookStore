@using BookStore.Models
@model Category

<div class="card shadow border-0 mt-4 sw-card">
    <div class="card-header sw-header ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="sw-header-text py-2 text-uppercase mb-0" style="letter-spacing: 2px;">Create Category</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4 p-md-5">
        <form method="post" class="row">
            <div class="p-4 rounded col-12" style="border: 1px solid rgba(46, 165, 255, 0.2); background: rgba(255, 255, 255, 0.02);">
                @* <div asp-validation-summary="ModelOnly" class="text-danger"></div> *@

                <div class="form-floating py-2 col-12 mb-3">
                    <input asp-for="Name" class="form-control sw-input" placeholder="Name" />
                    <label asp-for="Name" class="ms-2">Name</label>
                    <span asp-validation-for="Name" class="text-danger fw-bold mt-1 d-block"></span>
                </div>

                <div class="form-floating py-2 col-12 mb-4">
                    <input asp-for="DisplayOrder" class="form-control sw-input" placeholder="Display Order" />
                    <label asp-for="DisplayOrder" class="ms-2">Display Order</label>
                    <span asp-validation-for="DisplayOrder" class="text-danger fw-bold mt-1 d-block"></span>
                </div>

                <div class="row pt-2">
                    <div class="col-6 col-md-3 mb-3">
                        <button type="submit" class="btn sw-btn w-100 py-2">
                            <i class="bi bi-plus-circle me-1"></i> CREATE
                        </button>
                    </div>
                    <div class="col-6 col-md-3 mb-3">
                        <a asp-controller="Category" asp-action="Index" class="btn w-100 py-2 text-uppercase fw-bold" style="background: transparent; border: 2px solid #888; color: #ccc; transition: all 0.3s ease; letter-spacing: 1px;">
                            <i class="bi bi-arrow-left me-1"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}