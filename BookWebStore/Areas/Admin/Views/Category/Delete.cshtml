@using BookStore.Models
@model Category

<div class="card shadow border-0 mt-4 sw-card">
    <div class="card-header sw-header ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="sw-header-text py-2 text-uppercase mb-0" style="letter-spacing: 2px;">Delete Category</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4 p-md-5">
        <h5 class="text-center mb-4" style="color: #dc3545; letter-spacing: 1px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> Are you sure you want to delete this category?
        </h5>

        <form method="post">
            <input asp-for="Id" hidden />

            <div class="p-3 mt-2 rounded" style="border: 1px solid rgba(220, 53, 69, 0.3); background: rgba(255, 255, 255, 0.02);">
                @*x<div asp-validation-summary="ModelOnly"></div>*@

                <div class="form-floating py-2 col-12 mb-3">
                    <input asp-for="Name" disabled class="form-control sw-input" style="opacity: 0.7; cursor: not-allowed;" placeholder="Category Name" />
                    <label asp-for="Name" class="ms-2">Category Name</label>
                </div>

                <div class="form-floating py-2 col-12 mb-4">
                    <input asp-for="DisplayOrder" disabled class="form-control sw-input" style="opacity: 0.7; cursor: not-allowed;" placeholder="Display Order" />
                    <label asp-for="DisplayOrder" class="ms-2">Display Order</label>
                </div>

                <div class="row mt-4">
                    <div class="col-6 col-md-4">
                        <button type="submit" class="btn w-100 py-2 text-uppercase fw-bold" style="background: transparent; border: 2px solid #dc3545; color: #dc3545; box-shadow: inset 0 0 5px rgba(220, 53, 69, 0.2), 0 0 8px rgba(220, 53, 69, 0.4); letter-spacing: 2px; transition: all 0.3s ease;">
                            <i class="bi bi-trash-fill me-1"></i> DELETE
                        </button>
                    </div>
                    <div class="col-6 col-md-4">
                        <a asp-controller="Category" asp-action="Index" class="btn w-100 py-2 text-uppercase fw-bold" style="background: transparent; border: 2px solid #888; color: #ccc; transition: all 0.3s ease; letter-spacing: 1px;">
                            <i class="bi bi-arrow-left me-1"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>