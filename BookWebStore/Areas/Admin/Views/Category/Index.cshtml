@using BookStore.Models
@model List<Category>

<div class="card shadow border-0 mt-4 sw-card">
    <div class="card-header sw-header ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="sw-header-text py-2 text-uppercase" style="letter-spacing: 2px;">Category List</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <div class="row pb-3">
            <div class="col-6">
            </div>
            <div class="col-6 text-end">
                <a asp-controller="Category" asp-action="Create" class="btn sw-btn d-inline-flex align-items-center">
                    <i class="bi bi-plus-circle me-2"></i> CREATE NEW CATEGORY
                </a>
            </div>
        </div>

        <table class="table table-dark table-hover text-light align-middle" style="--bs-table-bg: transparent; --bs-table-border-color: rgba(46, 165, 255, 0.2);">
            <thead>
                <tr>
                    <th style="color: #FFE81F; border-bottom: 2px solid #2EA5FF; text-transform: uppercase; letter-spacing: 1px;">
                        Category Name
                    </th>
                    <th style="color: #FFE81F; border-bottom: 2px solid #2EA5FF; text-transform: uppercase; letter-spacing: 1px;">
                        Display Order
                    </th>
                    <th style="border-bottom: 2px solid #2EA5FF;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model.OrderBy(u => u.DisplayOrder))
                {
                    <tr style="background-color: rgba(10, 10, 14, 0.5); transition: all 0.2s ease;">
                        <td style="color: #e0e0e0; border-bottom: 1px solid rgba(46, 165, 255, 0.2); padding: 12px 8px;">
                            @category.Name
                        </td>
                        <td style="color: #e0e0e0; border-bottom: 1px solid rgba(46, 165, 255, 0.2); padding: 12px 8px;">
                            @category.DisplayOrder
                        </td>
                        <td style="border-bottom: 1px solid rgba(46, 165, 255, 0.2); padding: 12px 8px;">
                            <div class="w-75 btn-group" role="group">
                                <a asp-controller="Category" asp-action="Edit" asp-route-id="@category.Id" class="btn sw-btn btn-sm mx-2 d-inline-flex align-items-center justify-content-center">
                                    <i class="bi bi-pencil-square me-1"></i> Edit
                                </a>

                                <a asp-controller="Category" asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm mx-2 text-uppercase fw-bold d-inline-flex align-items-center justify-content-center" style="background: transparent; border: 2px solid #dc3545; color: #dc3545; box-shadow: inset 0 0 5px rgba(220, 53, 69, 0.2), 0 0 8px rgba(220, 53, 69, 0.4); letter-spacing: 1px; transition: all 0.3s ease;">
                                    <i class="bi bi-trash-fill me-1"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>