@using BookStore.Models
@using Models.BookWebStore
@using Models.BookWebStore.ViewModels
@model Company

<div class="card shadow border-0 mt-4 sw-card">
    <div class="card-header sw-header ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="sw-header-text py-2 text-uppercase mb-0" style="letter-spacing: 2px;">@(Model.Id == 0 ? "Create" : "Edit") Company</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4 p-md-5">
        <form method="post" class="row" enctype="multipart/form-data">
            <input asp-for="Id" hidden />

            <div class="row">
                <div class="col-12">
                    <div class="p-4 rounded" style="border: 1px solid rgba(46, 165, 255, 0.2); background: rgba(255, 255, 255, 0.02);">

                        @* <div asp-validation-summary="ModelOnly"></div> *@

                        <div class="form-floating py-2 col-12 mb-3">
                            <input asp-for="Name" class="form-control sw-input" placeholder="Company Name" />
                            <label asp-for="Name" class="ms-2">Company Name</label>
                            <span asp-validation-for="Name" class="text-danger fw-bold mt-1 d-block"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-floating py-2 mb-3">
                                <input asp-for="PhoneNumber" class="form-control sw-input" placeholder="Phone Number" />
                                <label asp-for="PhoneNumber" class="ms-3">Phone Number</label>
                                <span asp-validation-for="PhoneNumber" class="text-danger fw-bold mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6 form-floating py-2 mb-3">
                                <input asp-for="StreetAddress" class="form-control sw-input" placeholder="Street Address" />
                                <label asp-for="StreetAddress" class="ms-3">Street Address</label>
                                <span asp-validation-for="StreetAddress" class="text-danger fw-bold mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 form-floating py-2 mb-4">
                                <input asp-for="City" class="form-control sw-input" placeholder="City" />
                                <label asp-for="City" class="ms-3">City</label>
                                <span asp-validation-for="City" class="text-danger fw-bold mt-1 d-block"></span>
                            </div>
                            <div class="col-md-4 form-floating py-2 mb-4">
                                <input asp-for="State" class="form-control sw-input" placeholder="State" />
                                <label asp-for="State" class="ms-3">State</label>
                                <span asp-validation-for="State" class="text-danger fw-bold mt-1 d-block"></span>
                            </div>
                            <div class="col-md-4 form-floating py-2 mb-4">
                                <input asp-for="PostalCode" class="form-control sw-input" placeholder="Postal Code" />
                                <label asp-for="PostalCode" class="ms-3">Postal Code</label>
                                <span asp-validation-for="PostalCode" class="text-danger fw-bold mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="row pt-2">
                            <div class="col-6 col-md-4">
                                @if (Model.Id == 0)
                                {
                                    <button type="submit" class="btn sw-btn w-100 py-2">
                                        <i class="bi bi-plus-circle me-1"></i> CREATE
                                    </button>
                                }
                                else
                                {
                                    <button type="submit" class="btn sw-btn w-100 py-2">
                                        <i class="bi bi-save me-1"></i> UPDATE
                                    </button>
                                }
                            </div>
                            <div class="col-6 col-md-4 mb-3">
                                <a asp-controller="Company" asp-action="Index" class="btn w-100 py-2 text-uppercase fw-bold" style="background: transparent; border: 2px solid #888; color: #ccc; transition: all 0.3s ease; letter-spacing: 1px;">
                                    <i class="bi bi-arrow-left me-1"></i> Back to List
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.tiny.cloud/1/6xxekwlhbk0mhf9cihk6beenjcyfb1891cdg3cryh0491wmx/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>

    <script>
        // Инициализация на TinyMCE с тъмната тема (в случай че добавиш Textarea за Company Description)
        tinymce.init({
        selector: 'textarea',
        plugins: 'anchor autolink charmap codesample emoticons lists table visualblocks wordcount',
        toolbar: 'undo redo | blocks fontfamily fontsize | bold italic underline strikethrough| align lineheight | numlist bullist indent outdent',
        skin: 'oxide-dark',
        content_css: 'dark'
        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}