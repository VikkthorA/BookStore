@using Models.BookWebStore.ViewModels
@model List<OrderVM>
@{
    var status = Context.Request.Query["status"];
    var pending = "pending";
    var inprocess = "inprocess";
    var completed = "completed";
    var approved = "approved";
    var all = "all";

    switch (status)
    {
        case "pending":
            pending = "active sw-active-tab";
            break;
        case "inprocess":
            inprocess = "active sw-active-tab";
            break;
        case "completed":
            completed = "active sw-active-tab";
            break;
        case "approved":
            approved = "active sw-active-tab";
            break;
        default:
            all = "active sw-active-tab";
            break;
    }
}

<div class="card shadow border-0 mt-4 sw-card">
    <div class="card-header sw-header ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="sw-header-text py-2 text-uppercase" style="letter-spacing: 2px;">Order List</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <div class="d-flex justify-content-between pb-5 pt-2">
            <span></span>
            <ul class="list-group list-group-horizontal-sm sw-tabs">
                <a style="text-decoration:none;" asp-controller="Order" asp-action="Index" asp-route-status="inprocess">
                    <li class="list-group-item" @inprocess>In Process</li>
                </a>
                <a style="text-decoration:none;" asp-controller="Order" asp-action="Index" asp-route-status="pending">
                    <li class="list-group-item" @pending>Payment Pending</li>
                </a>
                <a style="text-decoration:none;" asp-controller="Order" asp-action="Index" asp-route-status="completed">
                    <li class="list-group-item" @completed>Completed</li>
                </a>
                <a style="text-decoration:none;" asp-controller="Order" asp-action="Index" asp-route-status="approved">
                    <li class="list-group-item" @approved>Approved</li>
                </a>
                <a style="text-decoration:none;" asp-controller="Order" asp-action="Index" asp-route-status="all">
                    <li class="list-group-item" @all>All</li>
                </a>
            </ul>
        </div>

        <table id="tblData" class="table table-dark table-hover text-light align-middle" style="width:100%; --bs-table-bg: transparent; --bs-table-border-color: rgba(46, 165, 255, 0.2);">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Phone Number</th>
                    <th>Email</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section Scripts {
    <script src="~/js/order.js"></script>
}