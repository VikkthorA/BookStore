<form method="post">
    <br />
    <div class="card shadow border-0 sw-card mt-2">
        <div class="card-header sw-header py-4 text-light">
            <div class="row px-4">
                <div class="col-6 d-flex align-items-center">
                    <h4 class="sw-header-text text-uppercase mb-0" style="letter-spacing: 2px;">
                        <i class="bi bi-cart3 me-2"></i> Shopping Cart
                    </h4>
                </div>
            </div>
        </div>
        <div class="card-body my-4 p-4 p-md-5">
            <div class="row mb-3 pb-3">
                <div class="col-md-3 offset-md-1 mb-4 mb-md-0">
                    <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn sw-btn text-uppercase btn-sm d-inline-flex align-items-center" style="font-size: 0.85rem;">
                        <i class="bi bi-arrow-left me-2"></i> Continue Shopping
                    </a>
                </div>

                <div class="col-md-10 offset-md-1 mt-4">
                    @foreach (var item in Model.ShoppingCartList)
                    {
                        <div class="row border-bottom pb-4 mb-4 align-items-center" style="border-color: rgba(46, 165, 255, 0.2) !important;">
                            <div class="d-none d-lg-block col-lg-2 text-center py-2">
                                <img src="@item.Product.ImgUrl" class="rounded shadow-lg" width="100%" style="border: 1px solid rgba(46, 165, 255, 0.3); object-fit: cover;" />
                            </div>
                            <div class="col-12 col-lg-5 pt-md-3">
                                <h5 class="text-uppercase mb-1" style="color: #2EA5FF; letter-spacing: 1px;"><strong>@item.Product.Title</strong></h5>
                                <div class="text-light opacity-75" style="font-size: 0.9rem;"><small>@Html.Raw(item.Product.Description)</small></div>
                            </div>
                            <div class="col-12 col-lg-5 text-center row align-items-center mt-3 mt-lg-0">
                                <div class="col-4 text-md-right pt-2 pt-md-4">
                                    <h6 class="fw-semibold text-white" style="font-size: 1.1rem;">
                                        @item.Price.ToString("c")
                                        <span class="text-light opacity-50 mx-1">x</span>
                                        <span style="color: #FFE81F;">@item.Count</span>
                                    </h6>
                                </div>
                                <div class="col-5 pt-2">
                                    <div class="w-100 btn-group" role="group">
                                        <a asp-action="plus" asp-route-cartId="@item.Id" class="btn sw-btn py-1 d-flex align-items-center justify-content-center">
                                            <i class="bi bi-plus-square"></i>
                                        </a> &nbsp;
                                        <a asp-action="minus" asp-route-cartId="@item.Id" class="btn sw-btn py-1 d-flex align-items-center justify-content-center">
                                            <i class="bi bi-dash-square"></i>
                                        </a>
                                    </div>
                                </div>
                                <div class="col-3 text-right pt-2">
                                    <a asp-action="remove" asp-route-cartId="@item.Id" class="btn py-1 d-flex align-items-center justify-content-center" style="background: transparent; border: 2px solid #dc3545; color: #dc3545; box-shadow: inset 0 0 5px rgba(220, 53, 69, 0.2), 0 0 8px rgba(220, 53, 69, 0.4); transition: all 0.3s ease;">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card-footer bg-transparent border-0 pb-5">
            <div class="row">
                <div class="col-md-6 offset-md-3 col-lg-4 offset-lg-4">
                    <ul class="list-group mb-4">
                        <li class="d-flex justify-content-between align-items-center p-3 rounded" style="background: rgba(46, 165, 255, 0.1); border: 1px solid #2EA5FF; box-shadow: inset 0 0 10px rgba(46, 165, 255, 0.2);">
                            <h5 class="text-white fw-semibold text-uppercase mb-0" style="letter-spacing: 1px;">Total (USD)</h5>
                            <h4 class="fw-bolder mb-0" style="color: #FFE81F;">@Model.OrderHeader.OrderTotal.ToString("c")</h4>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 offset-md-3 col-lg-4 offset-lg-4">
                    <a asp-action="Summary" class="btn sw-btn w-100 py-3 text-uppercase fw-bold" style="letter-spacing: 2px; font-size: 1.1rem;">
                        SUMMARY <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>