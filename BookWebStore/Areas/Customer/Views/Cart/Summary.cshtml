@using Models.BookWebStore.ViewModels
@model ShoppingCartVM

<form method="post">
	<br />
	<div class="container">
		<div class="card shadow border-0 sw-card">

			<div class="card-header sw-header text-light ml-0 py-4">
				<div class="row px-4 align-items-center">
					<div class="col-6">
						<h4 class="sw-header-text text-uppercase mb-0" style="letter-spacing: 2px;">
							<i class="bi bi-card-checklist me-2"></i> Order Summary
						</h4>
					</div>
					<div class="col-6 text-end">
						<a asp-action="Index" class="btn sw-btn btn-sm text-uppercase d-inline-flex align-items-center" style="font-size: 0.85rem;">
							<i class="bi bi-arrow-left me-2"></i> Back to Cart
						</a>
					</div>
				</div>
			</div>
			<div class="card-body p-4 p-md-5">
				<div class="container rounded p-0">
					<div class="row">
						<div class="col-12 col-lg-6 pb-4">
							<h4 class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom" style="border-color: rgba(46, 165, 255, 0.3) !important;">
								<span style="color: #2EA5FF; letter-spacing: 1px; text-transform: uppercase; font-size: 1.1rem;">Shipping Details</span>
							</h4>

							<div class="row my-2 align-items-center">
								<div class="col-3 text-light opacity-75">
									<label>Name</label>
								</div>
								<div class="col-9">
									<input asp-for="OrderHeader.Name" class="form-control sw-input" required />
									<span asp-validation-for="OrderHeader.Name" class="text-danger fw-bold mt-1 d-block"></span>
								</div>
							</div>
							<div class="row my-2 align-items-center">
								<div class="col-3 text-light opacity-75">
									<label>Phone</label>
								</div>
								<div class="col-9">
									<input asp-for="OrderHeader.PhoneNumber" class="form-control sw-input" required />
									<span asp-validation-for="OrderHeader.PhoneNumber" class="text-danger fw-bold mt-1 d-block"></span>
								</div>
							</div>
							<div class="row my-2 align-items-center">
								<div class="col-3 text-light opacity-75">
									<label>Street Address</label>
								</div>
								<div class="col-9">
									<input asp-for="OrderHeader.StreetAddress" class="form-control sw-input" required />
									<span asp-validation-for="OrderHeader.StreetAddress" class="text-danger fw-bold mt-1 d-block"></span>
								</div>
							</div>
							<div class="row my-2 align-items-center">
								<div class="col-3 text-light opacity-75">
									<label>City</label>
								</div>
								<div class="col-9">
									<input asp-for="OrderHeader.City" class="form-control sw-input" required />
									<span asp-validation-for="OrderHeader.City" class="text-danger fw-bold mt-1 d-block"></span>
								</div>
							</div>
							<div class="row my-2 align-items-center">
								<div class="col-3 text-light opacity-75">
									<label>State</label>
								</div>
								<div class="col-9">
									<input asp-for="OrderHeader.State" class="form-control sw-input" required />
									<span asp-validation-for="OrderHeader.State" class="text-danger fw-bold mt-1 d-block"></span>
								</div>
							</div>
							<div class="row my-2 align-items-center">
								<div class="col-3 text-light opacity-75">
									<label>Postal Code</label>
								</div>
								<div class="col-9">
									<input asp-for="OrderHeader.PostalCode" class="form-control sw-input" required />
									<span asp-validation-for="OrderHeader.PostalCode" class="text-danger fw-bold mt-1 d-block"></span>
								</div>
							</div>
						</div>

						<div class="col-12 col-lg-5 offset-lg-1 mt-5 mt-lg-0">
							<h4 class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom" style="border-color: rgba(46, 165, 255, 0.3) !important;">
								<span style="color: #2EA5FF; letter-spacing: 1px; text-transform: uppercase; font-size: 1.1rem;">Order Summary</span>
							</h4>

							<div class="sw-input p-2 mb-4">
								<ul class="list-group mb-0">
									@foreach (var details in Model.ShoppingCartList)
									{
										<li class="list-group-item d-flex justify-content-between p-3" style="background: transparent; border-color: rgba(46, 165, 255, 0.2);">
											<div>
												<h6 class="my-0 mb-1" style="color: #2EA5FF; font-size: 1.05rem;">@details.Product.Title</h6>
												<small class="text-light opacity-75">Quantity: @details.Count</small>
											</div>
											<span class="fw-bold d-flex align-items-center" style="color: #28a745; font-size: 1.1rem;">@((details.Price * details.Count).ToString("c"))</span>
										</li>
									}
									<li class="list-group-item d-flex justify-content-between align-items-center p-3 mt-2 rounded" style="background: rgba(46, 165, 255, 0.15); border: 1px solid #2EA5FF;">
										<small class="text-white text-uppercase fw-bold" style="letter-spacing: 1px;">Total (USD)</small>
										<strong style="color: #FFE81F; font-size: 1.25rem;">@Model.OrderHeader.OrderTotal.ToString("c")</strong>
									</li>
								</ul>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="card-footer bg-transparent border-0 px-4 px-md-5 pb-5 pt-0">
				<div class="row align-items-center">
					<div class="col-12 col-md-8 pt-2 mb-4 mb-md-0">
						<p class="mb-0" style="color: #FFE81F; font-size: 0.95rem; letter-spacing: 0.5px;">
							<i class="bi bi-clock-history me-1"></i> Estimate Arrival Date:
							<span class="text-white ms-1 fw-bold">@DateTime.Now.AddDays(7).ToShortDateString() - @DateTime.Now.AddDays(14).ToShortDateString()</span>
						</p>
					</div>
					<div class="col-12 col-md-4">
						<button type="submit" value="Place Order" class="btn w-100 py-3 text-uppercase fw-bold" style="background: transparent; border: 2px solid #28a745; color: #28a745; box-shadow: inset 0 0 5px rgba(40, 167, 69, 0.2), 0 0 10px rgba(40, 167, 69, 0.5); letter-spacing: 2px; transition: all 0.3s ease;">
							Place Order <i class="bi bi-check2-circle ms-1"></i>
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>
</form>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}