@using Models.BookWebStore
@model ShoppingCart

<form method="post">
    <input type="hidden" asp-for="ProductId" />
    <div class="card shadow border-0 mt-4 sw-card">
        <div class="card-header sw-header text-light py-4">
            <div class="row">
                <div class="col-12 text-center">
                    <h3 class="sw-header-text text-uppercase mb-1" style="letter-spacing: 2px;">@Model.Product.Title</h3>
                    <p class="text-white-50 fw-semibold mb-0" style="font-size: 1.1rem;">by <span style="color: #FFE81F;">@Model.Product.Author</span></p>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="py-3">
                <div class="row">
                    <div class="col-6 col-md-3 offset-lg-1 pb-1">
                        <a asp-action="Index" class="btn sw-btn mb-5 fw-semibold btn-sm text-uppercase d-inline-flex align-items-center">
                            <i class="bi bi-arrow-left me-2"></i> Back to home
                        </a>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 col-lg-3 offset-lg-1 text-center mb-3">
                        <img src="@Model.Product.ImgUrl" width="100%" class="rounded shadow-lg" style="border: 1px solid rgba(46, 165, 255, 0.3);" />
                    </div>
                    <div class="col-12 col-lg-6 offset-lg-1">

                        <div class="col-12 col-md-6 pb-4">
                            <span class="badge" style="background-color: #2EA5FF; color: #000; font-size: 0.9rem; padding: 6px 12px;">@Model.Product.Category.Name</span>
                        </div>
                        <div class="row ps-2">
                            <h6 class="text-light opacity-75">ISBN : @Model.Product.ISBN</h6>
                        </div>
                        <div class="row ps-2">
                            <h6 class="text-light opacity-75 pb-2">
                                List Price:
                                <span class="text-decoration-line-through text-danger">
                                    @Model.Product.ListPrice.ToString("c")
                                </span>
                            </h6>
                        </div>

                        <div class="row text-center ps-2 mt-2">
                            <div class="p-2 col-3 col-lg-2 border-bottom" style="border-color: rgba(255,255,255,0.1) !important; background: rgba(255,255,255,0.05);">
                                <div class="text-light opacity-75 fw-semibold">Quantity</div>
                            </div>
                            <div class="p-2 col-3 col-lg-2 border-bottom" style="border-color: rgba(255,255,255,0.1) !important; background: rgba(255,255,255,0.05);">
                                <div class="text-light opacity-75 fw-semibold">1-50</div>
                            </div>
                            <div class="p-2 col-3 col-lg-2 border-bottom" style="border-color: rgba(255,255,255,0.1) !important; background: rgba(255,255,255,0.05);">
                                <div class="text-light opacity-75 fw-semibold">51-100</div>
                            </div>
                            <div class="p-2 col-3 col-lg-2 border-bottom" style="border-color: rgba(255,255,255,0.1) !important; background: rgba(255,255,255,0.05);">
                                <div class="text-light opacity-75 fw-semibold">100+</div>
                            </div>
                        </div>
                        <div class="row text-center ps-2 mb-4">
                            <div class="p-2 col-3 col-lg-2" style="background: rgba(46, 165, 255, 0.1);">
                                <div class="fw-bold" style="color: #2EA5FF;">Price</div>
                            </div>
                            <div class="p-2 col-3 col-lg-2" style="background: rgba(46, 165, 255, 0.1);">
                                <div class="fw-bold text-white">@Model.Product.Price.ToString("c")</div>
                            </div>
                            <div class="p-2 col-3 col-lg-2" style="background: rgba(46, 165, 255, 0.1);">
                                <div class="fw-bold text-white">@Model.Product.Price50.ToString("c")</div>
                            </div>
                            <div class="p-2 col-3 col-lg-2" style="background: rgba(46, 165, 255, 0.1);">
                                <div class="fw-bold" style="color: #FFE81F;">@Model.Product.Price100.ToString("c")</div>
                            </div>
                        </div>

                        <div class="row pl-2 my-3">
                            <div class="text-light opacity-75 lh-base" style="font-size: 0.95rem;">@Html.Raw(Model.Product.Description)</div>
                        </div>

                        <div class="row pl-2 mb-4 mt-3">
                            <div class="col-md-5">
                                <div class="input-group">
                                    <span class="input-group-text border-0 fw-semibold"
                                          style="background-color: #2EA5FF; color: #000;" id="inputGroup-sizing-default">
                                        Count
                                    </span>
                                    <input asp-for="Count" type="number" value="1" class="form-control text-center sw-input"
                                           aria-label="Sizing example input" aria-describedby="inputGroup-sizing-default" style="font-weight: bold; font-size: 1.1rem;" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12 col-md-6 pb-1">
                                <button type="submit"
                                        class="btn sw-btn w-100 py-3 text-uppercase fw-bold" style="letter-spacing: 2px;">
                                    ADD TO CART
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>