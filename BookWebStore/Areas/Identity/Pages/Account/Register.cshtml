@page
@model RegisterModel
@using BookWebStore.Utility

<div class="container" style="max-width: 780px;">
    <div class="card shadow border-0 mt-4 sw-card">
        <div class="card-header sw-header ml-0 py-4">
            <div class="row">
                <div class="col-12 text-center">
                    @if (User.IsInRole(SD.Role_Admin))
                    {
                        <h2 class="py-2 sw-header-text m-0" style="font-weight: 800; letter-spacing: 4px; text-transform: uppercase;">Register - ADMIN PORTAL</h2>
                    }
                    else
                    {
                        <h2 class="py-2 sw-header-text m-0" style="font-weight: 800; letter-spacing: 4px; text-transform: uppercase;">Register</h2>
                    }
                </div>
            </div>
        </div>
        <div class="card-body p-4 p-md-5">
            <div class="row pt-3">
                <div class="col-md-12">
                    <form id="registerForm" class="row" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <h3 class="border-bottom pb-3 mb-4 sw-title-secondary text-center" style="font-size: 1.2rem; letter-spacing: 1px;">Create a new account.</h3>
                        <div asp-validation-summary="ModelOnly" class="text-danger fw-bold" role="alert"></div>

                        <div class="form-floating mb-4 col-md-12">
                            <input asp-for="Input.Email" class="form-control sw-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="ms-2">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 col-md-6">
                            <input asp-for="Input.Name" class="form-control sw-input" placeholder="name@example.com" />
                            <label asp-for="Input.Name" class="ms-2">Full Name</label>
                            <span asp-validation-for="Input.Name" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 col-md-6">
                            <input asp-for="Input.PhoneNumber" class="form-control sw-input" placeholder="name@example.com" />
                            <label asp-for="Input.PhoneNumber" class="ms-2">Phone Number</label>
                            <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 col-md-6">
                            <input asp-for="Input.Password" class="form-control sw-input" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password" class="ms-2">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 col-md-6">
                            <input asp-for="Input.ConfirmPassword" class="form-control sw-input" autocomplete="new-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.ConfirmPassword" class="ms-2">Confirm Password</label>
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 col-md-6">
                            <input asp-for="Input.Address" class="form-control sw-input" placeholder="name@example.com" />
                            <label asp-for="Input.Address" class="ms-2">Street Address</label>
                            <span asp-validation-for="Input.Address" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 col-md-6">
                            <input asp-for="Input.City" class="form-control sw-input" placeholder="name@example.com" />
                            <label asp-for="Input.City" class="ms-2">City</label>
                            <span asp-validation-for="Input.City" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 col-md-6">
                            <input asp-for="Input.State" class="form-control sw-input" placeholder="name@example.com" />
                            <label asp-for="Input.State" class="ms-2">State</label>
                            <span asp-validation-for="Input.State" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4 col-md-6">
                            <input asp-for="Input.PostalCode" class="form-control sw-input" placeholder="name@example.com" />
                            <label asp-for="Input.PostalCode" class="ms-2">Postal Code</label>
                            <span asp-validation-for="Input.PostalCode" class="text-danger"></span>
                        </div>

                        @if (User.IsInRole(SD.Role_Admin))
                        {
                            <div class="form-floating mb-4 col-md-6">
                                <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select sw-input">
                                    <option disabled selected>-Select Role-</option>
                                </select>
                            </div>
                            <div class="form-floating mb-4 col-md-6">
                                <select asp-for="Input.CompanyId" style="display:none;" asp-items="@Model.Input.CompanyList" class="form-select sw-input">
                                    <option disabled selected>-Select Company-</option>
                                </select>
                            </div>
                        }

                        <div class="col-12 mt-2">
                            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg sw-btn py-3">REGISTER</button>
                        </div>
                    </form>
                </div>

                @if (User.IsInRole(SD.Role_Admin))
                {
                    <div class="col-md-12 p-3 text-center mt-3">
                        <section>
                            <p class="sw-divider d-flex pt-3 mb-4">or</p>
                            <h3 class="sw-title-secondary mb-3" style="font-size: 1.1rem;">Use another service to register.</h3>
                            @{
                                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                                {
                                    <div>
                                        <p style="color: #888; font-size: 0.9rem;">
                                            There are no external authentication services configured. See this <a href="https://go.microsoft.com/fwlink/?LinkID=532715" class="sw-link">
                                            article about setting up this ASP.NET application to support logging in via external services
                                        </a>.
                                    </p>
                                </div>
                            }
                                else
                            {
                                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                                    <div class="d-flex justify-content-center gap-3 flex-wrap">
                                        @foreach (var provider in Model.ExternalLogins!)
                                        {
                                            <button type="submit" class="btn sw-btn px-4 py-2" name="provider" value="@provider.Name" title="Register using your @provider.DisplayName account">
                                                @provider.DisplayName
                                            </button>
                                        }
                                    </div>
                                </form>
                            }
                        }
                    </section>
                </div>
            }
        </div>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $('#Input_Role').change(function () {
                var selectedRole = $('#Input_Role option:selected').text();

                if (selectedRole === 'Company') {
                    $('#Input_CompanyId').show();
                } else {
                    $('#Input_CompanyId').hide();
                }
            });
        });
    </script>
}